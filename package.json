{
  "name": "echo",
  "description": "Echo desktop app",
  "author": "Echo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "mac:export": "expo export --platform web --output-dir dist/web",
    "mac:dev": "npm run mac:export && electron desktop/main.cjs",
    "mac:dir": "npm run mac:export && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir --arm64 --config desktop/electron-builder.yml",
    "mac:build:arm64": "npm run mac:export && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --arm64 --config desktop/electron-builder.yml",
    "mac:build:x64": "npm run mac:export && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --x64 --config desktop/electron-builder.yml",
    "mac:build": "npm run mac:export && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --arm64 --x64 --config desktop/electron-builder.yml",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:backend": "node scripts/audit-backend.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.0",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.2.3",
    "phosphor-react-native": "^3.0.4",
    "posthog-react-native": "^4.45.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@react-native/virtualized-lists": "0.81.5",
    "postcss": "8.5.10",
    "uuid": "11.1.1",
    "react-native": "0.81.5"
  },
  "private": true
}