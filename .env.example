# Copy to `.env` in this directory for local development.
# Expo loads EXPO_PUBLIC_* at build time, so those values are public in client bundles.
# `.env` is gitignored. Never commit real backend secrets.

# Supabase (project Settings > API). Leave unset to use offline mock data + Zustand.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# FastAPI chat stream (iOS Simulator: use http://127.0.0.1:8000; physical device: your LAN IP).
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Supabase project ref for local scripts and CLI linking.
SUPABASE_PROJECT_REF=your-project-ref

# Edge Function `echo-ai` (Supabase Dashboard > Edge Functions > Secrets — never ship in the Expo app):
# OPENROUTER_API_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# ECHO_AI_MODEL=

# Supabase setup checklist:
# 1. Create a project at https://supabase.com
# 2. Apply migrations: `supabase db push` (or use backend/db/schema.sql as reference in SQL Editor)
# 3. Authentication > Providers > Anonymous > enable (used on first onboarding when remote)
# 4. Paste URL + anon key above, restart Expo
