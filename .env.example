# Copy to `.env` in this directory for local development.
# Expo loads EXPO_PUBLIC_* at build time, so those values are public in client bundles.
# `.env` is gitignored. Never commit real backend secrets.

# ── Supabase — paste from supabase.com > Project Settings > API ──
# Leave unset to use offline mock data + Zustand.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project ref for local scripts and CLI linking.
SUPABASE_PROJECT_REF=

# ── Crash reporting ──
# Get from sentry.io > Project > Settings > Client Keys
EXPO_PUBLIC_SENTRY_DSN=

# ── Product analytics ──
# Get from app.posthog.com > Project Settings > Project API Key
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Public launch URLs and support contacts ──
# Use your owned HTTPS domain when privacy/support/terms pages are live.
EXPO_PUBLIC_WEB_BASE_URL=https://echo.app
EXPO_PUBLIC_SUPPORT_EMAIL=support@echo.app
EXPO_PUBLIC_DSA_EMAIL=dsa@echo.app

# ── App Review demo account ──
# Create a no-real-data demo user in Supabase Auth and set these only for review builds.
EXPO_PUBLIC_DEMO_EMAIL=
EXPO_PUBLIC_DEMO_PASSWORD=

# ── Consent storage key (override only if you renamed the key in MMKV) ──
EXPO_PUBLIC_ANALYTICS_CONSENT_KEY=echo_analytics_consent

# ── Uptime / status page (Better Uptime, Instatus, etc.) ──
STATUSPAGE_URL=

# ── Edge Function `echo-ai` (Supabase Dashboard > Edge Functions > Secrets — never ship in the Expo app) ──
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=          # content moderation (api.openai.com/v1/moderations)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# ECHO_AI_MODEL=

# Supabase setup checklist:
# 1. Create a project at https://supabase.com
# 2. Apply migrations: `supabase db push` (or use backend/db/schema.sql as reference in SQL Editor)
# 3. Authentication > Providers > Anonymous > enable (used on first onboarding when remote)
# 4. Paste URL + anon key above, restart Expo

# Production builds: set EAS Secrets instead of relying on .env, e.g.
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value https://xxx.supabase.co
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value eyJ...
#   eas secret:create --scope project --name EXPO_PUBLIC_SENTRY_DSN --value https://...@sentry.io/...
#   eas secret:create --scope project --name EXPO_PUBLIC_POSTHOG_KEY --value phc_...
#   eas secret:create --scope project --name EXPO_PUBLIC_POSTHOG_HOST --value https://us.i.posthog.com
#   eas secret:create --scope project --name EXPO_PUBLIC_WEB_BASE_URL --value https://your-domain.example
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPPORT_EMAIL --value support@your-domain.example
#   eas secret:create --scope project --name EXPO_PUBLIC_DSA_EMAIL --value dsa@your-domain.example
#   eas secret:create --scope project --name EXPO_PUBLIC_DEMO_EMAIL --value reviewer-demo@your-domain.example
#   eas secret:create --scope project --name EXPO_PUBLIC_DEMO_PASSWORD --value <demo-password>
