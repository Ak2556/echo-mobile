{
  "expo": {
    "name": "echo",
    "slug": "echo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "echo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ak2556.echo",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:echo.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Echo uses your microphone to record voice memos in the mini-apps section.",
        "NSCameraUsageDescription": "Echo uses your camera to take photos for your profile and marketplace listings.",
        "NSPhotoLibraryUsageDescription": "Echo accesses your photo library so you can upload photos to your profile, marketplace listings, and send images in direct messages.",
        "NSPhotoLibraryAddUsageDescription": "Echo saves images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "package": "com.ak2556.echo",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "echo.app",
              "pathPrefix": "/e"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF7F1",
          "dark": {
            "backgroundColor": "#0C0B09"
          }
        }
      ],
      "expo-web-browser",
      "expo-video",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Echo to access your microphone to record voice memos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6366F1",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Echo to access your photos to share images.",
          "cameraPermission": "Allow Echo to use your camera to take photos and videos."
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "echo-nb",
          "project": "react-native"
        }
      ],
      "expo-asset",
      "expo-build-properties",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a743cf66-7ec4-4ff0-ad2a-4088398b5654"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a743cf66-7ec4-4ff0-ad2a-4088398b5654"
    }
  }
}
